{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/data.js": {
      "memory": 1024
    },
    "api/refresh.js": {
      "memory": 1024
    },
    "api/search.mjs": {
      "memory": 1024
    }
  },
  "crons": [
    {
      "path": "/api/refresh",
      "schedule": "0 0,12 * * *"
    }
  ]
}
